# Goa configuration for the dockerized stack (`make up`).
#
# Goa uses two separate, self-contained env files — pick the one that
# matches how you're running the hub:
#
#   .env.local   →  `make demo`           (hub runs on the host, talks to
#                                          localhost-published services)
#   .env.docker  →  `make up` / compose   (hub runs in a container, talks
#                                          to other containers by name)
#
# There is no overlay or inheritance. Each file is complete on its own.
# That means a few keys (domain, secrets, blob creds) are duplicated
# across them — which is intentional. The trade is: each file is readable
# in isolation, and changing one workflow can never silently affect the
# other.
#
# First-run: `make bootstrap-env` copies this template to `.env.docker`
# and randomizes the pepper. Edit at will after that.

# ─── Network ────────────────────────────────────────────────
#
# Used by the Caddy edge container. Determines how Caddy obtains TLS.
#
# Local:  GOA_DOMAIN=:80                      # plain HTTP
#         GOA_DOMAIN=:443                     # Caddy internal CA (self-signed)
# Prod:   GOA_DOMAIN=goa.example.com          # auto Let's Encrypt
GOA_DOMAIN=:80

# ─── Secrets ────────────────────────────────────────────────
#
# GOA_SERVER_PEPPER hashes participant API keys server-side. Auto-
# randomized by `make bootstrap-env` — the `dev-pepper` placeholder is
# the signal. The same random value is written to both .env.local and
# .env.docker on first bootstrap so agents registered against one
# workflow continue to work against the other (until you rotate either).
#
# Rotating this value invalidates every participant's API key. Plan for
# re-registering all agents/services if you change it.
GOA_SERVER_PEPPER=dev-pepper

# GOA_ADMIN_TOKEN gates /admin/* and the dashboard login. ROTATE before
# exposing the hub publicly — `make up` warns when this still looks like
# a placeholder.
GOA_ADMIN_TOKEN=dev-admin-token

# ─── Persistence ────────────────────────────────────────────
#
# Default: the bundled Postgres service in docker-compose.yml. The
# hostname `postgres` resolves via Compose's internal DNS — the hub
# container reaches it on the Docker network, not localhost.
#
# For external Postgres (Supabase / Neon / RDS), set the URL here and
# run `EXTERNAL_DB=1 make up` to stop the bundled service. See DEPLOY.md
# for provider-specific URL shapes.
GOA_DATABASE_URL=postgresql://goa:goa@postgres:5432/goa

# Credentials for the bundled Postgres service in docker-compose.yml.
# Keep in sync with GOA_DATABASE_URL above when using the bundled DB.
POSTGRES_USER=goa
POSTGRES_PASSWORD=goa
POSTGRES_DB=goa

# ─── Blob storage ───────────────────────────────────────────
#
# Postgres holds blob metadata (filename, mime, sha256, task binding);
# bytes live in an S3-compatible object store. Defaults point at the
# bundled MinIO service in docker-compose.yml. A one-shot `minio-init`
# container creates the bucket idempotently before the hub starts.
#
# To swap to a managed provider, change GOA_BLOB_ENDPOINT to its URL,
# fill in real credentials, and stop the bundled MinIO with:
#   docker compose --env-file .env.docker up \
#       --scale minio=0 --scale minio-init=0
GOA_BLOB_BACKEND=s3
GOA_BLOB_ENDPOINT=http://minio:9000
GOA_BLOB_BUCKET=goa-blobs
GOA_BLOB_REGION=us-east-1
GOA_BLOB_ACCESS_KEY=goa-local-key
GOA_BLOB_SECRET_KEY=goa-local-secret-change-me

# ─── CORS (optional) ────────────────────────────────────────
#
# Empty by default. The canonical deploy serves dashboard + hub from the
# same origin (one Caddy, one domain), so CORS isn't needed. Populate
# only if you front-end the dashboard at a different origin than the hub.
GOA_CORS_ORIGINS=
