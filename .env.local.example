# Goa configuration for native local dev (`make demo`).
#
# Goa uses two separate, self-contained env files — pick the one that
# matches how you're running the hub:
#
#   .env.local   →  `make demo`           (hub runs on the host, talks to
#                                          localhost-published services)
#   .env.docker  →  `make up` / compose   (hub runs in a container, talks
#                                          to other containers by name)
#
# There is no overlay or inheritance. Each file is complete on its own.
# That means a few keys (domain, secrets, blob creds) are duplicated
# across them — which is intentional. The trade is: each file is readable
# in isolation, and changing one workflow can never silently affect the
# other.
#
# First-run: `make bootstrap-env` copies this template to `.env.local`
# and randomizes the pepper. Edit at will after that.

# ─── Network ────────────────────────────────────────────────
#
# Not used by `make demo` (the native hub binds 127.0.0.1:8000 directly,
# no Caddy in the loop). Kept here so the file shape matches .env.docker.
GOA_DOMAIN=:80

# ─── Secrets ────────────────────────────────────────────────
#
# GOA_SERVER_PEPPER hashes participant API keys server-side. Auto-
# randomized by `make bootstrap-env` — the `dev-pepper` placeholder is
# the signal. The same random value is written to both .env.local and
# .env.docker on first bootstrap so agents registered against one
# workflow continue to work against the other (until you rotate either).
GOA_SERVER_PEPPER=dev-pepper

# GOA_ADMIN_TOKEN gates /admin/* and the dashboard login. Short and
# memorable for dev convenience — rotate before exposing publicly.
GOA_ADMIN_TOKEN=dev-admin-token

# ─── Persistence ────────────────────────────────────────────
#
# Default: bundled Postgres on localhost:5432, started by
# `scripts/demo-db.sh` as a docker container with port 5432 published.
#
# For external Postgres (Supabase / Neon / RDS), set the URL here. The
# bundled container won't start when the URL points at a non-local host.
GOA_DATABASE_URL=postgresql://goa:goa@localhost:5432/goa

# Credentials for the bundled Postgres started by scripts/demo-db.sh.
# Keep in sync with GOA_DATABASE_URL above.
POSTGRES_USER=goa
POSTGRES_PASSWORD=goa
POSTGRES_DB=goa

# ─── Persistence — alternatives (uncomment exactly one) ─────
#
# SQLite — single file on disk, no Docker. Survives restarts; wiped by
# `make demo-clean`.
# GOA_DATABASE_URL=sqlite:./goa.db
#
# In-memory — fastest start, state vanishes on restart. Good for a first
# poke at the hub or transient tests.
# GOA_DATABASE_URL=

# ─── Blob storage ───────────────────────────────────────────
#
# Postgres holds blob metadata (filename, mime, sha256, task binding);
# bytes live in an S3-compatible object store. Defaults point at a
# bundled MinIO container started by scripts/demo-db.sh.
#
# To use AWS S3 / Cloudflare R2 / Supabase Storage / Backblaze B2,
# change GOA_BLOB_ENDPOINT to the provider's URL and fill in real
# credentials — the bundled MinIO won't start when the endpoint points
# at a non-local host.
#
# When using SQLite or the in-memory DB, swap to GOA_BLOB_BACKEND=db
# (bytes live alongside metadata) and ignore the other fields.
GOA_BLOB_BACKEND=s3
GOA_BLOB_ENDPOINT=http://localhost:9000
GOA_BLOB_BUCKET=goa-blobs
GOA_BLOB_REGION=us-east-1
GOA_BLOB_ACCESS_KEY=goa-local-key
GOA_BLOB_SECRET_KEY=goa-local-secret-change-me

# ─── CORS (optional) ────────────────────────────────────────
#
# Empty by default. The native demo serves dashboard (Vite, :5173) and
# hub (:8000) on different ports, but the dashboard dev server proxies
# /api → hub so they share an origin from the browser's POV. Populate
# only if you front the dashboard at a different origin yourself.
GOA_CORS_ORIGINS=
